<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- LOGIN -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.cafedealtura_dam.ui.autent.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />

        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <!-- REGISTER -->
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.cafedealtura_dam.ui.autent.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">

        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- HOME -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.cafedealtura_dam.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_productsFragment"
            app:destination="@id/productsFragment" />

        <action
            android:id="@+id/action_homeFragment_to_cartFragment"
            app:destination="@id/cartFragment" />

        <action
            android:id="@+id/action_homeFragment_to_profileFragment"
            app:destination="@id/profileFragment" />

        <action
            android:id="@+id/action_homeFragment_to_filteredProductsFragment"
            app:destination="@id/filteredProductsFragment" />
    </fragment>

    <!-- PRODUCTS -->
    <fragment
        android:id="@+id/productsFragment"
        android:name="com.example.cafedealtura_dam.ui.products.ProductsFragment"
        android:label="Productos"
        tools:layout="@layout/fragment_products">

        <action
            android:id="@+id/action_productsFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />

        <action
            android:id="@+id/action_productsFragment_to_cartFragment"
            app:destination="@id/cartFragment" />

        <action
            android:id="@+id/action_productsFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <!-- FILTERED PRODUCTS -->
    <fragment
        android:id="@+id/filteredProductsFragment"
        android:name="com.example.cafedealtura_dam.ui.home.FilteredProductsFragment"
        android:label="Productos filtrados"
        tools:layout="@layout/fragment_filtered_products">

        <action
            android:id="@+id/action_filteredProductsFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />

        <action
            android:id="@+id/action_filteredProductsFragment_to_cartFragment"
            app:destination="@id/cartFragment" />

        <action
            android:id="@+id/action_filteredProductsFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <!-- PRODUCT DETAIL -->
    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.example.cafedealtura_dam.ui.products.ProductDetailFragment"
        android:label="Detalle"
        tools:layout="@layout/fragment_product_detail">

        <action
            android:id="@+id/action_productDetailFragment_to_cartFragment"
            app:destination="@id/cartFragment" />

        <action
            android:id="@+id/action_productDetailFragment_to_profileFragment"
            app:destination="@id/profileFragment" />
    </fragment>

    <!-- CART -->
    <fragment
        android:id="@+id/cartFragment"
        android:name="com.example.cafedealtura_dam.ui.car_shop.CartFragment"
        android:label="Carrito"
        tools:layout="@layout/fragment_cart">

        <action
            android:id="@+id/action_cartFragment_to_productsFragment"
            app:destination="@id/productsFragment" />

        <action
            android:id="@+id/action_cartFragment_to_profileFragment"
            app:destination="@id/profileFragment" />

        <action
            android:id="@+id/action_cartFragment_to_paymentFragment"
            app:destination="@id/paymentFragment" />

        <action
            android:id="@+id/action_cartFragment_to_direccionPagosFragment"
            app:destination="@id/direccionPagosFragment" />

    </fragment>

    <fragment
        android:id="@+id/direccionPagosFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.pagos.DireccionPagosFragment"
        android:label="Dirección de envío"
        tools:layout="@layout/fragment_direccion_pagos" />

    <!-- PROFILE -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.ProfileFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profileFragment_to_ordersFragment"
            app:destination="@id/ordersFragment" />

        <action
            android:id="@+id/action_profileFragment_to_direccionesFragment"
            app:destination="@id/direccionesFragment" />

        <action
            android:id="@+id/action_profileFragment_to_paymentMethodsFragment"
            app:destination="@id/paymentMethodsFragment" />

        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />

        <action
            android:id="@+id/action_profileFragment_to_favoritosFragment"
            app:destination="@id/favoritosFragment" />
    </fragment>

    <!-- ORDERS -->
    <fragment
        android:id="@+id/ordersFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.pedidos.OrdersFragment"
        android:label="Mis pedidos"
        tools:layout="@layout/fragment_orders" />

    <!-- DIRECCIONES -->
    <fragment
        android:id="@+id/direccionesFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.direcciones.DireccionesFragment"
        android:label="Direcciones"
        tools:layout="@layout/fragment_direcciones" />
    <fragment
        android:id="@+id/seleccionarUbicacionFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.direcciones.SeleccionarUbicacionFragment"
        android:label="SeleccionarUbicacion" />

    <!-- SETTINGS -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.configuracion.SettingsFragment"
        android:label="Configuración"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_settingsFragment_to_changePasswordFragment"
            app:destination="@id/changePasswordFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_helpCenterFragment"
            app:destination="@id/helpCenterFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_supportFragment"
            app:destination="@id/supportFragment" />

    </fragment>

    <!-- CHANGE PASSWORD -->
    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.configuracion.ChangePasswordFragment"
        android:label="Cambiar contraseña"
        tools:layout="@layout/fragment_change_password" />

    <!-- HELP CENTER -->
    <fragment
        android:id="@+id/helpCenterFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.configuracion.centroAyu.HelpCenterFragment"
        android:label="Centro de ayuda"
        tools:layout="@layout/fragment_help_center" />

    <fragment
        android:id="@+id/supportFragment"
        android:name="com.example.cafedealtura_dam.ui.confi.SupportFragment"
        android:label="Soporte"
        tools:layout="@layout/fragment_support" />

    <!-- PAYMENT -->
    <fragment
        android:id="@+id/paymentFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.pagos.PaymentFragment"
        android:label="Pago"
        tools:layout="@layout/fragment_payment">

        <action
            android:id="@+id/action_paymentFragment_to_paymentSuccessFragment"
            app:destination="@id/paymentSuccessFragment" />
    </fragment>

    <!-- PAYMENT SUCCESS -->
    <fragment
        android:id="@+id/paymentSuccessFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.pagos.PaymentSuccessFragment"
        android:label="Pago completado"
        tools:layout="@layout/fragment_payment_success" />

    <!-- PAYMENT METHODS -->
    <fragment
        android:id="@+id/paymentMethodsFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.pagos.PaymentMethodsFragment"
        android:label="Métodos de pago"
        tools:layout="@layout/fragment_payment_methods" />

    <!-- ORDER DETAIL -->
    <fragment
        android:id="@+id/orderDetailFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.pedidos.OrderDetailFragment"
        android:label="Detalle del pedido"
        tools:layout="@layout/fragment_order_detail" />

    <!-- FAVORITOS -->
    <fragment
        android:id="@+id/favoritosFragment"
        android:name="com.example.cafedealtura_dam.ui.profile.favorito.FavoritosFragment"
        android:label="Favoritos"
        tools:layout="@layout/fragment_favoritos">

        <action
            android:id="@+id/action_favoritosFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />
    </fragment>

</navigation>