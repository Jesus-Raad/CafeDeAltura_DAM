<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F1EC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="20dp"
            android:contentDescription="Volver"
            android:src="@drawable/outline_arrow_back_24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Métodos de pago"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2B1B17"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestiona el método de pago disponible en tu cuenta"
            android:textSize="14sp"
            android:textColor="#7A6A58"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:id="@+id/cardPaypal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_payment_method_card"
            android:padding="18dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivPaypalLogo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="PayPal logo" />
                <!-- android:src="@drawable/ic_paypal" -->

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PayPal"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#2B1B17" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Método disponible para completar tus pedidos"
                        android:textSize="13sp"
                        android:textColor="#7A6A58"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Predeterminado"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#2F4F44"
                    android:background="@drawable/bg_payment_badge"
                    android:paddingLeft="10dp"
                    android:paddingTop="6dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="6dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#E6E0D9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tus pagos se procesarán de forma segura a través de PayPal Sandbox en esta versión demo."
                android:textSize="14sp"
                android:textColor="#2B1B17"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pulsa para continuar al checkout"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#0070BA"
                android:layout_marginTop="14dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>