<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cafe_fondo_principal"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ICONO -->
        <ImageView
            android:layout_width="78dp"
            android:layout_height="78dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_circle_light"
            android:padding="18dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/cafe_verde_montana" />

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="¡Pedido confirmado!"
            android:textColor="@color/cafe_marron_principal"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- SUBTITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="22dp"
            android:text="Tu pedido ha sido procesado exitosamente"
            android:textColor="@color/cafe_marron_suave"
            android:textSize="14sp" />

        <!-- NUMERO PEDIDO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@color/cafe_card_fondo"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:text="Número de pedido"
                android:textColor="@color/cafe_marron_suave"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_marginTop="6dp"
                android:text="ORD-XXXX"
                android:textColor="@color/cafe_marron_principal"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- DETALLES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@color/cafe_card_fondo"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:text="Detalles de entrega"
                android:textStyle="bold"
                android:textColor="@color/cafe_marron_principal"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Fecha estimada\n25 - 27 de marzo"
                android:textColor="@color/cafe_marron_principal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvSelectedAddressSuccess"
                android:text="Dirección de envío"
                android:textColor="@color/cafe_marron_principal"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvProductsCount"
                android:text="0 artículos"
                android:textColor="@color/cafe_marron_principal"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- RESUMEN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:background="@color/cafe_card_fondo"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:text="Resumen"
                android:textStyle="bold"
                android:textColor="@color/cafe_marron_principal"
                android:layout_marginBottom="14dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- SUBTOTAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_weight="1"
                    android:text="Subtotal"
                    android:textColor="@color/cafe_marron_suave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvSubtotalSuccess"
                    android:text="0.00 €"
                    android:textColor="@color/cafe_marron_principal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ENVIO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_weight="1"
                    android:text="Envío"
                    android:textColor="@color/cafe_marron_suave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvShippingSuccess"
                    android:text="0.00 €"
                    android:textColor="@color/cafe_marron_principal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="12dp"
                android:background="#E6E0DA" />

            <!-- TOTAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_weight="1"
                    android:text="Total"
                    android:textStyle="bold"
                    android:textColor="@color/cafe_marron_principal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTotalSuccess"
                    android:text="0.00 €"
                    android:textStyle="bold"
                    android:textColor="@color/cafe_marron_principal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- BOTONES -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:backgroundTint="@color/cafe_verde_montana"
            android:text="Volver al inicio"
            android:textAllCaps="false"
            android:textColor="@color/cafe_texto_boton"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>