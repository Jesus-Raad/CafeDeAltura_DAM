<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cafe_fondo_principal"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/outline_arrow_back_24"
            android:tint="@color/cafe_marron_principal"
            android:contentDescription="Volver" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp"
            android:text="Configuración"
            android:textColor="@color/cafe_marron_principal"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- CUENTA -->
        <TextView
            android:id="@+id/tvSectionAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Cuenta"
            android:textColor="@color/cafe_marron_suave"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/itemChangePassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_circle_icon"
                android:padding="10dp"
                android:src="@drawable/outline_lock_24"
                android:tint="@color/cafe_verde_montana"
                android:contentDescription="Cambiar contraseña" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cambiar contraseña"
                    android:textColor="@color/cafe_marron_principal"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Actualiza tu contraseña"
                    android:textColor="@color/cafe_marron_suave"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- SOPORTE -->
        <TextView
            android:id="@+id/tvSectionSupport"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Soporte"
            android:textColor="@color/cafe_marron_suave"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cardSupport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/cardHelpCenter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_circle_icon"
                    android:padding="10dp"
                    android:src="@drawable/outline_help_24"
                    android:tint="@color/cafe_verde_montana"
                    android:contentDescription="Centro de ayuda" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Centro de ayuda"
                        android:textColor="@color/cafe_marron_principal"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Preguntas frecuentes"
                        android:textColor="@color/cafe_marron_suave"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E0DA" />

            <LinearLayout
                android:id="@+id/itemContactSupport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_circle_icon"
                    android:padding="10dp"
                    android:src="@drawable/outline_mail_24"
                    android:tint="@color/cafe_verde_montana"
                    android:contentDescription="Contactar soporte" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contactar soporte"
                        android:textColor="@color/cafe_marron_principal"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="support@coffeeapp.com"
                        android:textColor="@color/cafe_marron_suave"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textColor="#D7263D"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="#F6DDDF"
            app:cornerRadius="18dp"
            app:icon="@drawable/outline_logout_24"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#D7263D" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Versión 1.0.0"
            android:textColor="@color/cafe_marron_suave"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>