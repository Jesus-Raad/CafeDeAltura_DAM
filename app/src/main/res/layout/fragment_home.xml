<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cafe_fondo_principal">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvSaludo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hola, María ☕"
            android:textColor="@android:color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubtitleHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Descubre cafés excepcionales"
            android:textSize="14sp"
            android:textColor="#6B6B6B"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@+id/tvSaludo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Search -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Buscar café..."
            android:layout_marginTop="18dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitleHome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Recomendados -->
        <TextView
            android:id="@+id/tvRecommended"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Recomendados para ti"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tilSearch"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Grid 2 columnas (sin Recycler por ahora, manual) -->
        <LinearLayout
            android:id="@+id/layoutRecommended"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvRecommended"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Card izquierda -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecommended1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/cafe_card_fondo"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/imgRec1"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:contentDescription="Producto" />

                    <TextView
                        android:id="@+id/tvRecName1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Colombia La Casita"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/tvRecOrigin1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Huila, Colombia"
                        android:textColor="#6B6B6B"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvRecMeta1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="250g · En grano"
                        android:textColor="#6B6B6B"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvRecPrice1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$24.90"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card derecha -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecommended2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/cafe_card_fondo"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <ImageView
                        android:id="@+id/imgRec2"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:contentDescription="Producto" />

                    <TextView
                        android:id="@+id/tvRecName2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Etiopía Sidamo"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/tvRecOrigin2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sidome, Etiopía"
                        android:textColor="#6B6B6B"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tvRecMeta2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="250g · En grano"
                        android:textColor="#6B6B6B"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvRecPrice2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$28.90"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Orígenes -->
        <TextView
            android:id="@+id/txtOrigins"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Orígenes populares"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRecommended"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <HorizontalScrollView
            android:id="@+id/hsvOrigins"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:paddingEnd="12dp"
            app:layout_constraintTop_toBottomOf="@id/txtOrigins"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/layoutOrigins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="4dp">

                <!-- Item origen 1 -->
                <LinearLayout
                    android:id="@+id/itemOriginCostaRica"
                    android:layout_width="104dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOriginCostaRica"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/cafe_card_fondo"
                        app:strokeWidth="0dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgOriginCostaRica"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:contentDescription="Costa Rica"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvOriginCostaRica"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Costa Rica"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />
                </LinearLayout>

                <!-- Item origen 2 -->
                <LinearLayout
                    android:id="@+id/itemOriginColombia"
                    android:layout_width="104dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOriginColombia"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/cafe_card_fondo"
                        app:strokeWidth="0dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgOriginColombia"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:contentDescription="Colombia"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvOriginColombia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Colombia"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />
                </LinearLayout>

                <!-- Item origen 3 -->
                <LinearLayout
                    android:id="@+id/itemOriginEtiopia"
                    android:layout_width="104dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOriginEtiopia"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/cafe_card_fondo"
                        app:strokeWidth="0dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgOriginEtiopia"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:contentDescription="Etiopía"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvOriginEtiopia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Etiopía"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />
                </LinearLayout>

                <!-- Item origen 4 -->
                <LinearLayout
                    android:id="@+id/itemOriginKenia"
                    android:layout_width="104dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOriginKenia"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/cafe_card_fondo"
                        app:strokeWidth="0dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgOriginKenia"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:contentDescription="Kenia"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvOriginKenia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Kenia"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />
                </LinearLayout>

                <!-- Item origen 5 -->
                <LinearLayout
                    android:id="@+id/itemOriginLaos"
                    android:layout_width="104dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOriginLaos"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        app:cardCornerRadius="44dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="@color/cafe_card_fondo"
                        app:strokeWidth="0dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgOriginLaos"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_gallery"
                            android:contentDescription="Laos"
                            app:shapeAppearanceOverlay="@style/CircleImage" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvOriginLaos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Laos"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Categorías -->
        <TextView
            android:id="@+id/tvCategories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Categorías"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/hsvOrigins"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/layoutCategories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvCategories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="@color/cafe_card_fondo"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Café en grano"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Para moler en casa"
                        android:textColor="#6B6B6B"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/cafe_card_fondo"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Café molido"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Listo para preparar"
                        android:textColor="#6B6B6B"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/cafe_card_fondo"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ediciones especiales"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lotes limitados"
                        android:textColor="#6B6B6B"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>