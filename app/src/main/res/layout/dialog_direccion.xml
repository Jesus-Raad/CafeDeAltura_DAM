<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre de la dirección"
        android:textSize="12sp"
        android:textColor="#7A6A58"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Casa, Oficina"
        android:inputType="text"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre completo"
        android:textSize="12sp"
        android:textColor="#7A6A58"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etNombrePersona"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: María García"
        android:inputType="textPersonName"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calle y número"
        android:textSize="12sp"
        android:textColor="#7A6A58"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etCalle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Calle Principal #123"
        android:inputType="textPostalAddress"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ciudad, País"
        android:textSize="12sp"
        android:textColor="#7A6A58"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etCiudad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Bogotá, Colombia"
        android:inputType="text"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Código postal"
        android:textSize="12sp"
        android:textColor="#7A6A58"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etCodigoPostal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: 110111"
        android:inputType="number"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Teléfono"
        android:textSize="12sp"
        android:textColor="#7A6A58"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/etTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: +57 300 123 4567"
        android:inputType="phone"
        android:background="@drawable/bg_input"
        android:padding="12dp"/>

</LinearLayout>