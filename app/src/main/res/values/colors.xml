<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== IDENTIDAD CAFÉ DE ALTURA ===== -->

    <!-- Fondo principal de la app (beige frío elegante) -->
    <color name="cafe_fondo_principal">#F3F1EC</color>

    <!-- Fondo de cards -->
    <color name="cafe_card_fondo">#FFFFFF</color>

    <!-- Verde principal de marca (botones / elementos activos) -->
    <color name="cafe_verde_montana">#2F4F44</color>

    <!-- Marrón café para títulos -->
    <color name="cafe_marron_principal">#2B1B17</color>

    <!-- Marrón suave para textos secundarios -->
    <color name="cafe_marron_suave">#7A6A58</color>

    <!-- Negro suave para textos fuertes -->
    <color name="cafe_negro_suave">#1C1B1A</color>

    <!-- Dorado suave (solo detalles premium si quieres usarlo) -->
    <color name="cafe_dorado_suave">#C2A878</color>

    <!-- Texto principal -->
    <color name="texto_principal">@color/cafe_marron_principal</color>

    <!-- Texto secundario -->
    <color name="texto_secundario">@color/cafe_marron_suave</color>

    <!-- Fondo del bottom navigation -->
    <color name="bottom_nav_background">#FFFFFF</color>

    <!-- Fondo del bottom  -->
    <color name="cafe_texto_boton">@android:color/white</color>
</resources>